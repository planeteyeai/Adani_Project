# GeoVision backend configuration
# Copy to .env and adjust. PostgreSQL is the default (as requested).

DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1

# --- PostgreSQL (default) ---
DB_NAME=geovision
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# --- Zero-config fallback ---
# Set USE_SQLITE=1 to run without a PostgreSQL server (uses a local db.sqlite3).
USE_SQLITE=0
